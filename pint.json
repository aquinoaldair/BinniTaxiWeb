{
    "$schema": "vendor/laravel/pint/resources/schema.json",
    "preset": "psr12",
    "rules": {
        "no_unused_imports": true,
        "ordered_imports": {
            "sort_algorithm": "alpha"
        }
    },
    "exclude": [
        "bootstrap/cache",
        "node_modules",
        "storage",
        "vendor"
    ]
}
